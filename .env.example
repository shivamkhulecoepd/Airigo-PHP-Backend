# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=airigo_job_portal
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-key-change-in-production
JWT_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=604800

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_STORAGE_BUCKET=your-storage-bucket.appspot.com

# Firebase Messaging Configuration
FIREBASE_MESSAGING_SENDER_ID=812788069887
FIREBASE_APP_ID=1:812788069887:web:f7a1b1c1d1e1f1a1b1c1d1
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DATABASE=0

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC